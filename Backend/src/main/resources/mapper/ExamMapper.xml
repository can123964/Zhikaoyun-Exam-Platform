<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.zhikaoyunexamplatform.exam.mapper.ExamMapper">

    <sql id="notDeleted">is_deleted = 0</sql>

    <select id="countByConditions" resultType="int">
        SELECT COUNT(*) FROM t_exam WHERE <include refid="notDeleted"/>
        <if test="status != null">AND status = #{status}</if>
        <if test="keyword != null and keyword != ''">AND title LIKE CONCAT('%', #{keyword}, '%')</if>
        <if test="creatorId != null">AND creator_id = #{creatorId}</if>
    </select>

    <select id="selectPage" resultType="org.example.zhikaoyunexamplatform.exam.vo.ExamVO">
        SELECT * FROM t_exam WHERE <include refid="notDeleted"/>
        <if test="status != null">AND status = #{status}</if>
        <if test="keyword != null and keyword != ''">AND title LIKE CONCAT('%', #{keyword}, '%')</if>
        <if test="creatorId != null">AND creator_id = #{creatorId}</if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <!-- 批量根据 ID 列表查询考试 -->
    <select id="selectByIds" resultType="org.example.zhikaoyunexamplatform.exam.entity.Exam">
        SELECT * FROM t_exam WHERE <include refid="notDeleted"/>
        AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>

</mapper>
