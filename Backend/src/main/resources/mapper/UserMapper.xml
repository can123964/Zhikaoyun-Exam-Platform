<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.zhikaoyunexamplatform.user.mapper.UserMapper">

    <!-- 逻辑删除状态常量，对应 DeletedStatusEnum -->
    <sql id="notDeleted">is_deleted = 0</sql>
    <sql id="deleted">is_deleted = 1</sql>

    <!-- 按主键更新用户，只更新非 null 字段 -->
    <update id="updateById">
        UPDATE t_user
        <set>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
            <if test="classId != null">class_id = #{classId},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id} AND <include refid="notDeleted"/>
    </update>

    <!-- 按条件统计用户总数 -->
    <select id="countByConditions" resultType="int">
        SELECT COUNT(*) FROM t_user WHERE <include refid="notDeleted"/>
        <if test="role != null">AND role = #{role}</if>
        <if test="keyword != null and keyword != ''">
            AND (username LIKE CONCAT('%', #{keyword}, '%')
                 OR real_name LIKE CONCAT('%', #{keyword}, '%'))
        </if>
    </select>

    <!-- 按条件分页查询用户 -->
    <select id="selectPage" resultType="org.example.zhikaoyunexamplatform.user.entity.User">
        SELECT * FROM t_user WHERE <include refid="notDeleted"/>
        <if test="role != null">AND role = #{role}</if>
        <if test="keyword != null and keyword != ''">
            AND (username LIKE CONCAT('%', #{keyword}, '%')
                 OR real_name LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY create_time DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 批量根据 ID 列表查询用户 -->
    <select id="selectByIds" resultType="org.example.zhikaoyunexamplatform.user.entity.User">
        SELECT * FROM t_user WHERE <include refid="notDeleted"/>
        AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>

    <!-- 最近注册的用户（活动动态用） -->
    <select id="selectRecentRegistrations" resultType="org.example.zhikaoyunexamplatform.user.entity.User">
        SELECT real_name AS realName, role, create_time AS createTime
        FROM t_user WHERE <include refid="notDeleted"/>
        ORDER BY create_time DESC
        LIMIT 50
    </select>

</mapper>
